pipeline {
    agent any

    stages {

        stage('Get Code') {
            steps {
                echo 'Getting code from GitHub'

                git 'https://github.com/sergiozapatero/cp1.1-devops.git'

                sh 'pwd'
                sh 'ls -l'
            }
        }

        stage('Build') {
            steps {
                echo 'Python project, no compilation needed'
            }
        }

        stage('Unit Tests') {
            steps {

                sh '''
                    export PYTHONPATH=$WORKSPACE
                    pytest --junitxml=result-unit.xml test/unit
                '''
            }
        }

        stage('REST Tests') {
            steps {

                sh '''
                    export PYTHONPATH=$WORKSPACE
                    export FLASK_APP=app/api.py

                    flask run --host=0.0.0.0 &
                    sleep 5

                    java -jar $WORKSPACE/wiremock/wiremock.jar --port 9090 --root-dir test/wiremock &
                    sleep 5

                    pytest --junitxml=result-rest.xml test/rest
                '''
            }
        }

        stage('Results') {
            steps {
                junit 'result*.xml'
            }
        }
    }
}
